<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- แผนที่เต็มจอ -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <!-- ปุ่มกลับตำแหน่งตัวเอง -->
    <Button
        android:id="@+id/locateMeButton"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:background="#CC1565C0"
        android:text="📍"
        android:textSize="20sp"
        android:textAllCaps="false"
        android:padding="0dp" />

    <!-- แถบคำแนะนำด้านบน (แสดงตอน pick mode) -->
    <TextView
        android:id="@+id/tapHintBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC1565C0"
        android:gravity="center"
        android:padding="10dp"
        android:text="แตะบนแผนที่เพื่อเพิ่มจุดเดิน"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <!-- ════════════ PICK MODE PANEL ════════════ -->
    <LinearLayout
        android:id="@+id/pickPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#E8000000"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="18dp">

        <!-- สถานะจำนวนจุด -->
        <TextView
            android:id="@+id/waypointCountText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="10dp"
            android:text="แตะแผนที่เพื่อเพิ่มจุด (ยังไม่มีจุด)"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp" />

        <!-- ปุ่ม ลบล่าสุด + ล้างทั้งหมด -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/undoButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:enabled="false"
                android:text="↩ ลบล่าสุด"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/clearButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:enabled="false"
                android:text="🗑 ล้างทั้งหมด"
                android:textAllCaps="false" />

        </LinearLayout>

        <!-- ปุ่มเริ่มนำทาง + ดาวน์โหลดแผนที่ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/startNavButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:layout_marginEnd="4dp"
                android:enabled="false"
                android:text="เริ่มนำทาง →"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/downloadMapButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="⬇ offline"
                android:textAllCaps="false"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ════════════ NAV MODE PANEL ════════════ -->
    <LinearLayout
        android:id="@+id/navPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#E8000000"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:visibility="gone">

        <!-- ชื่อจุดที่กำลังมุ่งหน้าไป -->
        <TextView
            android:id="@+id/targetLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="4dp"
            android:text="มุ่งหน้า: จุดที่ 1"
            android:textColor="#FFCC00"
            android:textSize="13sp" />

        <!-- ลูกศรชี้ทิศทาง -->
        <ImageView
            android:id="@+id/arrowView"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="ทิศทางนำทาง"
            android:src="@drawable/ic_arrow" />

        <!-- ระยะทางที่เหลือ -->
        <TextView
            android:id="@+id/distanceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="10dp"
            android:text="ระยะทางที่เหลือ: -- เมตร"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- ปุ่มหยุด -->
        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="■ หยุดนำทาง"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>

</FrameLayout>
